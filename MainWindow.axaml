</Window.Resources>   
    <Grid>
        <Image x:Name="ImageShow" Stretch="UniformToFill" Opacity="0.7"/>
        <Grid x:Name="mainGrid">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" x:Name="NavigatePannel" Background="{DynamicResource BackgroundBrush}">
                <!--StackPanel.Background>
                    <ImageBrush
ImageSource="/Background.png"
Stretch="Fill" Opacity="0.8"/>
                </StackPanel.Background-->
                <TextBlock Text="NAVIGATION"  Margin="15,20,10,10"  Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold"/>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"  Click="GoToMainPage">
                    <DockPanel>
<Path Data="{StaticResource SquareChartGanttRegular}" Width="14" Height="14"
      Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="主菜单" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    
                </Button>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"  Click="GoToConfigPage">
                    <DockPanel>
<Path Data="{StaticResource Gear}" Width="14" Height="14"
      Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="可配置项" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"   Click="GoToVersionManagementPage">
                    <DockPanel>
<Path Data="{StaticResource ListUnordered}" Width="10" Height="10"
Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="版本管理" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"  Click="GoToToolboxPage" >
                    <DockPanel>
<Path Data="{StaticResource AiModel}" Width="14" Height="14"
      Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="杂项" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    
                </Button>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"  Click="GoToDownloadPage">
                    <DockPanel>
<Path Data="{StaticResource Download}" Width="14" Height="14"
Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="安装" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
                <Button Margin="10" Height="40" HorizontalAlignment="Left" Width="150"  Click="GoToAboutPage">
                    <DockPanel>
<Path Data="{StaticResource Info}" Width="17" Height="17"
Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" />                        <TextBlock Text="关于" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>
            </StackPanel>
            <ContentControl x:Name="ContentArea" Grid.Column="1"/>
            
        </Grid>
        
    </Grid>
</Window>
