    </UserControl.Resources>     

  <Grid>
        
        <Grid>
            <DockPanel Margin="10">

                
                    <Border  CornerRadius="4" Padding="10" Margin="10" VerticalAlignment="Bottom" HorizontalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="5" Width="150"  Margin="10,0,10,0" Background="{DynamicResource BackgroundBrush}">

                                <Grid Margin="10" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                        <Path Data="{StaticResource LanguageJavaText}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="-25,0,0,20"/>
                                        <TextBlock Text="Java版本" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        <TextBlock Grid.Row="1" Text="{Binding JavaDisplayInfo}" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="5" Width="150"  Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                        
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                        <Path Data="{StaticResource HardDrives}" Width="35" Height="35"
                                              Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>
                                        <TextBlock Text="游戏版本" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        <TextBlock Grid.Row="1" Text="{Binding SelectedVersionInfo}" HorizontalAlignment="Center" MaxWidth="130" Margin="0,0,0,18"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                        <Path Data="{StaticResource User}" Width="35" Height="35"
                                              Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>
                                        <TextBlock Text="玩家ID" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        <TextBox 
                                            Text="{Binding PlayerName}" Margin="0,0,0,5"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="3" CornerRadius="5" Width="150" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="150">
                                        <Path Data="{StaticResource RocketLaunch}" Width="35" Height="35"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>
                                        <TextBlock Text="游戏" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        <ToggleButton  
                                         HorizontalAlignment="Center"
                                        FontSize="13" 
                                        Height="30"
                                        Width="100" 
                                        Command="{Binding LaunchCommand}"
                                        x:Name="LauchGame"    Margin="20,0,20,5" Grid.Row="1">
                                            <ToggleButton.Content>
                                                <TextBlock Text="启动" HorizontalAlignment="Center"/>
                                            </ToggleButton.Content>
                                        </ToggleButton>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
