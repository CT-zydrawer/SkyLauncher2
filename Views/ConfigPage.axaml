    </UserControl.Resources>
    <Grid>
         <Border  CornerRadius="4" Padding="10" Margin="10" VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="{DynamicResource RegionBrush}">
        <ScrollViewer>
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <GroupBox Header="通用配置项" FontSize="15" Grid.Row="0" Margin="10" Padding="10" >

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Grid.Row="0">
                            <StackPanel 
                                HorizontalAlignment="Left">
                                <TextBlock Text="配置内存使用" Margin="20,10,20,10" />
                                <DockPanel
                                    HorizontalAlignment="Left"
                                    Margin="10">
                                    <DockPanel>
                                    <RadioButton
                                        x:Name="manual_allocation"
                                        GroupName="mem_allocation_mode"
                                        Content="手动分配"
                                        
                                        IsChecked="{Binding IsManualCollocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Orientation="Vertical" Spacing="32">
                                        <Slider Width="400" 
                                                IsSnapToTickEnabled="True" 
                                                Minimum="1024"
                                                Maximum="{Binding FreeMemory}"
                                                Value="{Binding MaxMemory, UpdateSourceTrigger=PropertyChanged}" 
                                                IsEnabled="{Binding IsManualCollocation}"
                                                TickFrequency="128" 
                                                TickPlacement="BottomRight" 
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left" 
                                                Margin="20,0,0,15"
                                                />
                                    </StackPanel>
                                    <TextBlock Text="{Binding MaxMemory, StringFormat='当前设置: {0} MB'}" Margin="20,0,20,10" Foreground="{DynamicResource SecondaryTextBrush}" MinWidth="150" VerticalAlignment="Center"/>
                                   </DockPanel>
                                </DockPanel>
                                <DockPanel
                                    HorizontalAlignment="Left"
                                    Margin="10,10,10,20">
                                    <RadioButton
                                        GroupName="mem_allocation_mode"
                                        Content="自动分配"
                                        IsChecked="{Binding IsAutoCollocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                </DockPanel>
                            </StackPanel>

                        </Border>
                        <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Grid.Row="1" Margin="0,15,0,0">
                            <StackPanel>
                                
                                    <TextBlock Text="选择Java" Margin="20,10,20,0"/>

                                <StackPanel Orientation="Horizontal" Margin="15,10,15,15" Spacing="8">
                                    <TextBlock Text="选择Java版本" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox Margin="10,0,0,0" 
          ItemsSource="{Binding JavaList}" 
          SelectedItem="{Binding SelectedJava}" 
           
          Width="230" />

                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="添加" Margin="15,0,0,0"  FontSize="15"
        Command="{Binding AddJavaCommand}" Classes="Primary"/>

                                    <Button 
              Content="自动寻找Java" Margin="15,0,0,0" FontSize="15" 
              Command="{Binding AutoDetectJavaCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource RegionBrush}" Grid.Row="2" Margin="0,15,0,0">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="5" Width="110" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0" Tapped="GoToMinecraftSettingPage">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
<Path Data="{StaticResource PuzzleOutline}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>                                                                                                          <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                            <TextBlock Text="模组" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" CornerRadius="5" Width="110" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0" 
                                        Tapped="OpenScreenshotGallery">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
<Path Data="{StaticResource Images}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>                                                                                                          <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="80">
                                            <TextBlock Text="截图画廊" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5,10,5,5"/>
                                            
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="2" CornerRadius="5" Width="110" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0"
                                        Tapped="OpenResourcePackManager">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
<Path Data="{StaticResource PackageBold}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>                                                                                                          <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100">
                                            <TextBlock Text="资源包" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                            

                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="3" CornerRadius="5" Width="110" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0" Tapped="OpenShaderpackManage">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
<Path Data="{StaticResource Blend}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>                                                                  
                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="100" >
                                            <TextBlock Text="光影包" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="4" CornerRadius="5" Width="110" Opacity="0.9" Background="{DynamicResource BackgroundBrush}" Margin="10,0,10,0"
                                        Tapped="OpenSchematicsManage">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
<Path Data="{StaticResource CameraRotate}" Width="30" Height="30"
                                        Stretch="UniformToFill" Fill="{DynamicResource IconBrush}" Margin="0,5,0,20"/>                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="150">
                                            <TextBlock Text="投影" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>
                <GroupBox Header="可传递配置项" FontSize="15" Grid.Row="1" Margin="10" Padding="10" >
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" MinHeight="80">
                        <TextBlock Text="未实现" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </GroupBox>

            </Grid>
        </ScrollViewer>
             </Border>
    </Grid>
</UserControl>
